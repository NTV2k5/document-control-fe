{
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/.server/**/*",
    "**/.client/**/*",
    "reactjs-platform/**/*.ts",
    "reactjs-platform/**/*.tsx"
  ],
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node", "vite/client", "wicg-file-system-access"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "paths": {
      "reactjs-platform/ui": ["./reactjs-platform/ui/index.ts"],
      "reactjs-platform/ui/*": ["./reactjs-platform/ui/*"],
      "reactjs-platform/utilities": ["./reactjs-platform/utilities/index.ts"],
      "reactjs-platform/utilities/*": ["./reactjs-platform/utilities/*"],
      "api": ["./src/api/index.ts"],
      "api/*": ["./src/api/*"]
    },
    "allowJs": true,
    "checkJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true
  },
  "exclude": ["node_modules", "build", "dist"]
}
